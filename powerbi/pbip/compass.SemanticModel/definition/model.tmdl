model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-AU

role Manager
	modelPermission: read

role Advisor_ADV01
	modelPermission: read
	tablePermission dim_advisor = [advisor_id] = "ADV01"

role Advisor_ADV09_Online
	modelPermission: read
	tablePermission dim_advisor = [advisor_id] = "ADV09"
