                "    Typed = Table.TransformColumnTypes(Selected, {{\"student_id\", type text}, {\"unit_code\", type text}, {\"term_code\", type text}, {\"campus_code\", type text}, {\"enrolment_status\", type text}, {\"grade\", type text}, {\"mark\", type number}, {\"eftsl\", type number}, {\"census_date\", type date}, {\"passed\", type text}, {\"eftsl_certified\", type number}, {\"eftsl_passed\", type number}})",
                "in",
