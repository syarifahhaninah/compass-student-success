        "lineageTag": "4c6d5571-ba15-4656-bb52-ca0b93b7d58a",
        "measures": [
          {
            "name": "Headcount",
            "expression": "DISTINCTCOUNT(fact_enrolment[student_id])",
            "formatString": "#,0",
            "lineageTag": "fd3a6f3c-cfdd-498f-b9fe-b5c01d652472"
          },
          {
            "name": "EFTSL Certified",
            "expression": "SUM(fact_enrolment[eftsl_certified])",
            "formatString": "#,0.0",
            "lineageTag": "caeaf411-896d-4bbf-99f4-2914378ea290"
          },
          {
            "name": "EFTSL Passed",
            "expression": "SUM(fact_enrolment[eftsl_passed])",
            "formatString": "#,0.0",
            "lineageTag": "accb486d-8706-4da4-bae3-6faadf45d123"
          },
          {
            "name": "Success Rate",
            "expression": "DIVIDE([EFTSL Passed], CALCULATE(SUM(fact_enrolment[eftsl_certified]), fact_enrolment[grade] <> \"IP\"))",
            "formatString": "0.0%",
            "lineageTag": "e50baa34-6f8a-4a75-8ea7-cc40b01b0fd9"
          },
          {
            "name": "Average Mark",
            "expression": "CALCULATE(AVERAGE(fact_enrolment[mark]), fact_enrolment[mark] >= 0, fact_enrolment[mark] <= 100)",
            "formatString": "0.0",
            "lineageTag": "2c137ab8-036b-4dd3-bdb7-c49f3cbf2f79"
          },
          {
            "name": "Pre-Census Withdrawals",
            "expression": "CALCULATE(COUNTROWS(fact_enrolment), fact_enrolment[enrolment_status] = \"Withdrawn pre-census\")",
            "formatString": "#,0",
            "lineageTag": "ac1aced1-8a71-4bf1-807a-1a8a4f8245b2"
          }
        ],
        "partitions": [
          {
            "name": "fact_enrolment",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(DataFolder & \"\\fact_enrolment.csv\"), [Delimiter = \",\", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),",
